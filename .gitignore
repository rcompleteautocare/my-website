# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# OAuth2 token cache
.searchconsole-token.json
lib/client_secret_*.apps.googleusercontent.com.json

# Lighthouse / audit reports
lh-report.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
