# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# HTTP server
PORT=3333

# Shared secret required on the Tekmetric webhook (sent as ?token= or the
# X-Webhook-Token header). Pick a long random string and configure the same
# value in Tekmetric's webhook settings.
TEKMETRIC_WEBHOOK_SECRET=replace-me

# --- RingCentral --------------------------------------------------------------
# App credentials (Server-only / JWT auth flow) from the RingCentral dev console.
RINGCENTRAL_SERVER=https://platform.ringcentral.com
RINGCENTRAL_CLIENT_ID=replace-me
RINGCENTRAL_CLIENT_SECRET=replace-me
# JWT credential minted for the shop's user (JWT auth flow).
RINGCENTRAL_JWT=replace-me
# The RingCentral number that sends SMS and originates RingOut calls (E.164).
# Must be A2P 10DLC registered for automated SMS to deliver.
RINGCENTRAL_FROM_NUMBER=+12192622711

# --- Tekmetric ----------------------------------------------------------------
# OAuth2 client-credentials app from Tekmetric.
TEKMETRIC_BASE_URL=https://sandbox.tekmetric.com
TEKMETRIC_CLIENT_ID=replace-me
TEKMETRIC_CLIENT_SECRET=replace-me
TEKMETRIC_SHOP_ID=replace-me

# --- Shop / behavior ----------------------------------------------------------
SHOP_NAME=R Complete Auto Care
SHOP_PHONE=+12192622711
# IANA timezone used for quiet-hours + reminder scheduling.
SHOP_TIMEZONE=America/Chicago
# Public links used in message bodies.
BOOKING_URL=https://www.rcompleteautocare.com/book
RESCHEDULE_URL=https://www.rcompleteautocare.com/book

# Minutes to wait for an SMS reply before placing the fallback call.
FALLBACK_DELAY_MINUTES=30

# Quiet hours (shop local time, 24h). No SMS/calls sent outside this window.
QUIET_HOURS_START=8
QUIET_HOURS_END=20
