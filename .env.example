# Template for .env.local — copy to .env.local and fill in real values.
# Never commit .env.local.

INTERNAL_KEY=replace-me

# Set to "true" to enable Tekmetric writes from inbound webhook
TEKMETRIC_ENABLED=false

TEKMETRIC_API_KEY=replace-me
TEKMETRIC_SHOP_ID=replace-me
TEKMETRIC_BASE_URL=replace-me

# --- Google rating drift check (weekly Vercel cron -> /api/rating-drift) ---
# Google Places API (New) key, restricted to Places API. Server-side only.
PLACES_API_KEY=replace-me
# Optional: overrides the PLACE_ID constant in lib/place.js if set.
# PLACES_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxxxxxxx
# Shared secret protecting the cron route. Set the SAME value in Vercel's
# project env so cron requests are authorized. Leave unset to skip the check.
CRON_SECRET=replace-me

# Drift alert webhook (e.g. Zapier/Make catch hook). If unset, drift is logged
# (visible in Vercel cron logs) but not pushed anywhere.
DRIFT_WEBHOOK_URL=replace-me

# --- Google Ads conversion tracking ---
# Base Google Ads tag id (gtag.js). Set in Vercel for Production + Preview.
NEXT_PUBLIC_ADS_TAG_ID=AW-18068510962
# Conversion label for the "Click to call" action (phone-link clicks). Combined
# with NEXT_PUBLIC_ADS_TAG_ID as `send_to: <tagId>/<label>`. NEXT_PUBLIC_ vars
# are inlined at BUILD time, so set this in Vercel (Production + Preview) and
# redeploy with build cache OFF before verifying.
NEXT_PUBLIC_ADS_PHONE_CONVERSION_LABEL=DSu9CKnb27wcEPKx3qdD

# --- Command Center ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/r_complete_command_center?schema=public"
AUTH_SECRET="replace-with-a-random-32-character-secret"
AUTH_TRUST_HOST="true"
DEMO_ADMIN_EMAIL="owner@rcomplete.com"
DEMO_ADMIN_PASSWORD="ChangeMe123!"
