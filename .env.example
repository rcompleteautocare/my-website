# Template for .env.local — copy to .env.local and fill in real values.
# Never commit .env.local.

INTERNAL_KEY=replace-me

# Google Ads global site tag (gtag.js) ID, format AW-XXXXXXXXXX.
# Public (NEXT_PUBLIC_) because it ships to the browser. Must also be set in
# the Vercel project env for BOTH Production and Preview. If unset, the gtag
# script is not rendered.
NEXT_PUBLIC_ADS_TAG_ID=AW-XXXXXXXXXX

# Google Ads "Click to call" conversion label (the part after the slash in
# send_to, e.g. AbCdEfGhIj). Paired with NEXT_PUBLIC_ADS_TAG_ID to fire a
# conversion when a tel: link is clicked. Must also be set in Vercel for
# BOTH Production and Preview. If unset, phone-click tracking is a no-op.
NEXT_PUBLIC_ADS_PHONE_CONVERSION_LABEL=XxXxXxXxXxXxXxXxXxXx

# Set to "true" to enable Tekmetric writes from inbound webhook
TEKMETRIC_ENABLED=false

TEKMETRIC_API_KEY=replace-me
TEKMETRIC_SHOP_ID=replace-me
TEKMETRIC_BASE_URL=replace-me
